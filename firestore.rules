rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields:
    //   - id: string (required)
    //   - username: string (required)
    //   - color: string (required)
    //   - shape: string (optional)
    //   - pixelCount: number (required)
    //   - lastUpdated: number (required)
    //
    // Collection: pixels
    // Fields:
    //   - id: string (required)
    //   - x: number (required)
    //   - y: number (required)
    //   - color: string (required)
    //   - shape: string (optional)
    //   - ownerId: string (required)
    //   - ownerName: string (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((request.auth.token.email == "Jaabo.ay@gmail.com" && request.auth.token.email_verified == true) ||
         request.auth.token.firebase.sign_in_provider == 'anonymous' ||
         request.auth.provider_id == 'anonymous');
    }

    // Validation Functions
    function isValidUser(data) {
      return data.keys().hasAll(['id', 'username', 'color', 'pixelCount', 'lastUpdated']) &&
             data.id is string &&
             data.username is string && data.username.size() > 0 &&
             data.color is string &&
             data.pixelCount is number &&
             data.lastUpdated is number &&
             (!('shape' in data) || data.shape is string) &&
             (!('rewards' in data) || data.rewards is list);
    }

    function isValidPixel(data) {
      return data.keys().hasAll(['id', 'x', 'y', 'color', 'ownerId', 'ownerName']) &&
             data.id is string &&
             data.x is number &&
             data.y is number &&
             data.color is string &&
             data.ownerId is string &&
             data.ownerName is string &&
             (!('shape' in data) || data.shape is string);
    }

    // Rules
    match /users/{userId} {
      allow read: if true; // Publicly readable for the canvas
      allow create, update: if isAdmin() && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }

    match /pixels/{pixelId} {
      allow read: if true; // Publicly readable for the canvas
      allow create, update: if isAdmin() && isValidPixel(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
